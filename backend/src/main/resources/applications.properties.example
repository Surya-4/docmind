spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/docmind_db}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:docmind}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:docmind123}
spring.jpa.hibernate.ddl-auto=${SPRING_JPA_HIBERNATE_DDL_AUTO:validate}
spring.jpa.properties.hibernate.jdbc.time_zone=${SPRING_JPA_PROPERTIES_HIBERNATE_JDBC_TIME_ZONE:Asia/Kolkata}
spring.jpa.properties.hibernate.dialect=${SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT:org.hibernate.dialect.PostgreSQLDialect}
spring.data.redis.host=${SPRING_REDIS_HOST:localhost}
spring.data.redis.port=${SPRING_REDIS_PORT:6379}
spring.data.redis.password=${SPRING_REDIS_PASSWORD:}
spring.data.redis.ssl.enabled=${SPRING_REDIS_SSL:false}
jwt.secret=${JWT_SECRET:docmind_secret}
jwt.expiration=${JWT_EXPIRATION:86400000}
fastapi.url=${FASTAPI_URL:http://localhost:8000}
supabase.url=${SUPABASE_URL}
supabase.key=${SUPABASE_KEY}
supabase.bucket=${SUPABASE_BUCKET:docmind-pdfs}
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
spring.application.name=docmind-backend
server.port=8080